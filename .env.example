# Deployment settings. Copy to .env.local and edit locally.
# Do not put AWS access keys, AWS secret keys, SSH private keys, or proxy secrets here.

# AWS Lightsail
AWS_REGION=ap-northeast-1
AWS_AZ=ap-northeast-1a
LIGHTSAIL_INSTANCE_NAME=proxy-tokyo-01
LIGHTSAIL_BUNDLE_ID=nano_3_0
LIGHTSAIL_BLUEPRINT_ID=ubuntu_24_04
AWS_PROFILE=

# Existing Lightsail key pair name. The private key stays on your machine or ssh-agent.
SSH_KEY_NAME=
SSH_USER=ubuntu
SSH_ALLOWED_CIDR=0.0.0.0/0

# Static IP is off by default because fast rebuild usually wants a fresh IP.
USE_STATIC_IP=false
LIGHTSAIL_STATIC_IP_NAME=proxy-tokyo-static-01
RELEASE_STATIC_IP_ON_DELETE=false

# Proxy node metadata
NODE_NAME=aws-tokyo-clean
SERVER_IP=

# VLESS Reality public settings
REALITY_SERVER_NAME=www.cloudflare.com
REALITY_DEST=www.cloudflare.com:443
REALITY_FINGERPRINT=chrome

# Optional Hysteria2 backup protocol on UDP 443
HYSTERIA_ENABLED=true
HYSTERIA_SNI=www.microsoft.com
HYSTERIA_MASQUERADE_URL=https://www.microsoft.com/

# Versions. Empty means latest at provisioning time.
XRAY_VERSION=
HYSTERIA_VERSION=

# Rebuild behavior
REBUILD_DELETE_OLD=false
